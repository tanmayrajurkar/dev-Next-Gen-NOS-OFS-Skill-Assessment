#
# OFS Data Processing System Config
# Master configuration File
#
# PARAMETER values are set as PARAMETER=value.
# Any comments must start with a # and must be on a
# separate line. Parameter names must be unique and must
# start at the beginning of a line. Parameters are grouped
# and denoted by [groupname] at the start of a set of parameters.
# Parameters in a group should have a 2-5 character prefix for the
# area they belong to, for example database specific stuff is
# prefixed by DB_.
#
# Note: keys are case-insensitive and stored in lowercase

[directories]
#-- Directory info and other config parameters ------------------------

# Application home directory - other directories will be subdirs
# to home, denoted by %(home)s

home=/path/to/sa_homedir/

# Data directory
#data_dir=%(home)s/data/
data_dir=data

# OFS directories
ofs_extents_dir=ofs_extents
control_files_dir=control_files
observations_dir=observations
1d_station_dir=1d_station
2d_satellite_dir=2d_satellite
2d_satellite_ice_dir=2d_satellite_ice
model_dir=model
skill_dir=skill
model_historical_dir=%(home)s/example_data
model_obc_dir=%(home)s/example_data
netcdf_dir=netcdf
1d_node_dir=1d_node
horizon_model_dir=horizon_model
model_icesave_dir=2D_ice_cover
1d_pair_dir=1d_pair
1d_ice_pair_dir=1d_ice_pair
1d_horizon_pair_dir=1d_horizon_pair
stats_dir=stats
stats_ice_dir=ice_stats
visual_dir=visual
visual_ice_dir=ice_visual
visual_ice_time_series=time_series
visual_ice_static_maps=static_maps
visual_ice_json_maps=json_maps
visual_ice_stats=stats
visual_horizon_dir=horizon_visual
om_dir=om_files
om_dir_ice=om_files_ice
tidal_analysis_dir=tidal_analysis
model_historical_dir_backup=Add_model_historical_dir_backup

# Local fallback path for the vertical datum NetCDF file. Only used if the
# vdatum file cannot be read from the NODD S3 bucket (noaa-nos-ofs-pds).
# Set this to the full path of a local copy of {ofs}_vdatums.nc.
local_vdatum = Add_path_to/file.nc

[urls]
# Station URLs
co_ops_mdapi_base_url=https://api.tidesandcurrents.noaa.gov/mdapi/prod/
co_ops_api_base_url=https://api.tidesandcurrents.noaa.gov/api/prod/
usgs_nwls_inventory_url=https://waterdata.usgs.gov/nwis/
usgs_nwis_url=https://nwis.waterservices.usgs.gov/nwis/iv/
ndbc_noaa_url=https://www.ndbc.noaa.gov/
ndbc_station_metadata_url=%(ndbc_noaa_url)s/metadata/stationmetadata.xml
glsea_thredds=https://apps.glerl.noaa.gov/thredds/fileServer/glsea_ice_nc/
glsea_erddap=https://apps.glerl.noaa.gov/erddap/files/GL_Ice_Concentration_GCS/
nodd_s3=https://noaa-nos-ofs-pds.s3.amazonaws.com/
nodd_s3_stofs3d = https://noaa-nos-stofs3d-pds.s3.amazonaws.com/
nodd_s3_stofs2d = https://noaa-gestofs-pds.s3.amazonaws.com/
#sat urls
nesdis_thredds=https://www.star.nesdis.noaa.gov/thredds/fileServer/
nesdis_n20=https://www.star.nesdis.noaa.gov/pub/socd2/coastwatch/sst/nrt/viirs/n20/l3u
nesdis_n21=https://www.star.nesdis.noaa.gov/pub/socd2/coastwatch/sst/nrt/viirs/n21/l3u
nesdis_npp=https://www.star.nesdis.noaa.gov/pub/socd2/coastwatch/sst/nrt/viirs/npp/l3u
nesdis_coastwatch=https://www.star.nesdis.noaa.gov/data/pub0053/coastwatch/sst/l3s
nesdis_dodsC=https://www.star.nesdis.noaa.gov/thredds/dodsC
nssr_sport=https://nssrgeo.ndc.nasa.gov/SPoRT/enhanced_sst/ghrsst_netcdf


[datums]
# List of vertical datums that the program can convert between. If a new datum
# is added to the package, include it here!
datum_list = MHHW MHW MLLW MLW NAVD88 IGLD85 LWD XGEOID20B


[station_IDs]
# Optional input list of observation station IDs to assess. 
# This list can only be actiavted by using the `list` argument
# for the flag -so --Station_Owner:
# `-so list`
# OR
# `--Station_Owner list`
# If using `-so list` and the list below is blank, the skill 
# assessment will include all stations found in an OFS.
station_ID_list = 8551910 8571421


[user_xy_inputs]
# Optional path to text file of coordinates that can be
# used in get_node_ofs.py to extract model time series at
# specific coordinates. Each line in file should correspond
# to one location. Formatting is as follows:
#
# location_name latitude longitude waterdepth
#
# where lat & lon are decimal degrees and depth is m.
# For example:
#    myloc1 39.582 -75.589 0
#    myloc2 37.996 -76.464 2
user_xy_path = path/to/filename.txt


[parallelization]
# -----------------------------------------------------------------------
# Parallelization settings
#
# All worker count settings accept either a positive integer or "auto".
# "auto" scales the worker count based on your system's CPU count:
#   - I/O-bound tasks (obs retrieval, model download, plotting, skill):
#     scales up to ~2x CPU count, since threads mostly wait on network/disk
#   - CPU-bound tasks (harmonic analysis): uses cpu_count - 1, capped at 8
#
# Set parallel_enabled=False to disable all parallelization and run
# everything sequentially (all worker counts forced to 1).
# -----------------------------------------------------------------------

parallel_enabled=True

# Observation retrieval (ThreadPoolExecutor, I/O-bound)
# CO-OPS and NDBC APIs handle concurrent requests well; USGS and CHS
# are rate-limited, so fewer workers are recommended.
obs_coops_workers=auto
obs_usgs_workers=auto
obs_ndbc_workers=auto
obs_chs_workers=auto

# Model file downloads from NODD S3 (ThreadPoolExecutor, I/O-bound)
model_download_workers=auto

# Skill assessment station pairing + metrics (ThreadPoolExecutor, I/O-bound)
skill_workers=auto

# Harmonic analysis (ProcessPoolExecutor, CPU-bound)
# Uses separate processes for utide, which releases the GIL.
ha_workers=auto

# Station plot generation (ThreadPoolExecutor, I/O-bound)
plot_workers=auto

# Variable-level parallelism (experimental)
# Process multiple variables (wl, temp, salt, cu) concurrently within
# a single pipeline stage. Only enable if you have sufficient memory.
parallel_variables=False

# Workflow-level parallelism: run obs download + model extraction concurrently
parallel_workflow=False

# Station-level parallelism: process stations in parallel during model extraction
parallel_stations=False

# Plotting parallelism: generate station plots in parallel
parallel_plotting=False

# Forecast cycle parallelism: process forecast_a cycles concurrently
parallel_forecast_cycles=False

# Obs variable parallelism: download obs for all variables concurrently
parallel_obs_variables=False

# 2D interpolation parallelism: run IDW interpolation for variables in parallel
parallel_2d_interp=False


[settings]
# Would you like to make static (.png) station plots in addition to
# the interactive plotly plots?
# True = both static & interactive plots
# False = just interactive plots
static_plots=False

# Use S3 fallback for missing model files?
# True = automatically read from NODD S3 bucket if local files are missing
# False = exit with error if local files are missing (original behavior)
use_s3_fallback=True
